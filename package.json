  ],
  "author": "Aman Asmuei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amanasmuei/acore.git"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "clipboardy": "^4.0.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
