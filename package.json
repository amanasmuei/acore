{
  "name": "@aman_asmuei/acore",
  "version": "0.1.1",
  "description": "The identity layer for AI companions — give any AI a persistent personality and relationship memory",
  "type": "module",
  "bin": {
    "acore": "./bin/acore.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
